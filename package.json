{
  "name": "antellion",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @antellion/db generate",
    "db:push": "pnpm --filter @antellion/db push",
    "db:migrate": "pnpm --filter @antellion/db migrate",
    "db:studio": "pnpm --filter @antellion/db studio",
    "db:seed": "pnpm --filter @antellion/db seed"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "effect": "^3.20.0",
      "defu": "^6.1.7"
    }
  }
}
